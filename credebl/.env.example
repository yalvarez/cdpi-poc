# =============================================================================
# CDPI PoC — CREDEBL Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in ALL values marked as REQUIRED
# Values marked as OPTIONAL have sensible defaults for PoC use
# NEVER commit .env to git — it is in .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=credebl
POSTGRES_PASSWORD=             # REQUIRED — choose a strong password
POSTGRES_DB=credebl
# Docker does not expand ${POSTGRES_PASSWORD} inside env_file values, so write
# the full URL here. Avoid special characters like @ in the password — they are
# invalid in base64 and will crash schema-file-server.
DATABASE_URL=postgresql://credebl:YOUR_POSTGRES_PASSWORD@postgres:5432/credebl
POOL_DATABASE_URL=postgresql://credebl:YOUR_POSTGRES_PASSWORD@postgres:5432/credebl

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Leave blank for the self-contained PoC. Upstream CREDEBL queue workers
# connect to Redis without a password, and enabling `requirepass` breaks issuance.
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# NATS
# ---------------------------------------------------------------------------
# The self-contained PoC NATS container does not enforce auth, so use `none`.
# Upstream CREDEBL defaults to `nkey`, which requires many *_NKEY_SEED values.
NATS_AUTH_TYPE=none
NATS_URL=nats://nats:4222

# ---------------------------------------------------------------------------
# Keycloak (OIDC provider)
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=       # REQUIRED — choose a strong password for the Keycloak admin console
# Must end with a trailing slash because the seed container builds URLs as
# ${KEYCLOAK_DOMAIN}realms/<realm>/protocol/openid-connect/token
KEYCLOAK_DOMAIN=http://keycloak:8080/
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_MASTER_REALM=master
KEYCLOAK_REALM=credebl-realm
KEYCLOAK_CLIENT_ID=credebl-client
KEYCLOAK_CLIENT_SECRET=        # REQUIRED — generate: openssl rand -hex 32
# The imported realm includes a dedicated confidential admin client named `adminClient`
# for the bootstrap flow. Reuse the same secret as `KEYCLOAK_CLIENT_SECRET` for simplicity.
KEYCLOAK_MANAGEMENT_CLIENT_ID=adminClient
KEYCLOAK_MANAGEMENT_CLIENT_SECRET=  # REQUIRED — copy the same value as KEYCLOAK_CLIENT_SECRET
PLATFORM_ADMIN_KEYCLOAK_ID=adminClient
PLATFORM_ADMIN_KEYCLOAK_SECRET=     # REQUIRED — copy the same value as KEYCLOAK_CLIENT_SECRET
PLATFORM_ADMIN_OLD_CLIENT_ID=
# Initial Studio/platform admin password. Keep `changeme` for the default PoC
# or replace it with your preferred first-login password.
PLATFORM_ADMIN_INITIAL_PASSWORD=changeme

# Public URL — used by external clients (wallet apps) to reach Keycloak
# In PoC: http://YOUR_VPS_IP:8080
# On day 5 (real OIDC swap): replace with country's real OIDC issuer URL
KEYCLOAK_PUBLIC_URL=http://YOUR_VPS_IP:8080

# ---------------------------------------------------------------------------
# MinIO (replaces AWS S3 — fully containerized)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=           # REQUIRED — choose a strong password
# Host port for MinIO console (internal container port remains 9001).
# Keep this away from AFJ spawned agent ports to avoid bind conflicts.
MINIO_CONSOLE_PORT=9011

# These values are what CREDEBL services use (S3-compatible API)
# Set them before first boot — the `minio-setup` service will create the user automatically.
AWS_ACCESS_KEY_ID=             # REQUIRED — e.g. credebls3
AWS_SECRET_ACCESS_KEY=         # REQUIRED — e.g. use only letters/numbers
AWS_ENDPOINT=http://minio:9000
AWS_REGION=us-east-1           # MinIO ignores this but CREDEBL requires a value
S3_BUCKET_NAME=credebl-bucket

# ---------------------------------------------------------------------------
# Mailpit (replaces SendGrid — fully containerized)
# ---------------------------------------------------------------------------
# Mailpit runs an SMTP server on port 1025
# All sent emails are captured and viewable at http://YOUR_VPS_IP:8025
# EMAIL_PROVIDER=smtp routes all email through SMTP (Mailpit) and bypasses
# SendGrid SDK validation entirely — SENDGRID_API_KEY is ignored in this mode.
# IMPORTANT: do NOT put inline comments on value lines — bash includes them in the variable.
EMAIL_PROVIDER=smtp
SENDGRID_API_KEY=SG.mock-not-used
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=mailpit
SMTP_PASS=mailpit
EMAIL_FROM=noreply@cdpi-poc.local

# ---------------------------------------------------------------------------
# CREDEBL Platform
# ---------------------------------------------------------------------------
API_GATEWAY_PROTOCOL=http
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=5000
PLATFORM_SEED=                 # REQUIRED — generate: openssl rand -hex 16
JWT_SECRET=                    # REQUIRED — generate: openssl rand -hex 32
JWT_EXPIRY=1d
NEXTAUTH_SECRET=               # REQUIRED — generate: openssl rand -hex 32 (used by Studio)
NEXTAUTH_COOKIE_DOMAIN=        # OPTIONAL — leave blank for raw IP deployments

# Public host:port of the API gateway (used in QR links and Swagger server URLs)
# IMPORTANT: keep this as host:port only — no http:// prefix.
API_ENDPOINT=YOUR_VPS_IP:5000
VPS_IP=YOUR_VPS_IP          # bare IP, used by Studio for NEXTAUTH_COOKIE_DOMAIN

# CREDEBL platform URL (for email links)
# In PoC: http://YOUR_VPS_IP:5000
PLATFORM_WEB_URL=http://YOUR_VPS_IP:5000
FRONT_END_URL=http://YOUR_VPS_IP:5000
# Keep this exact origin with no trailing slash.
STUDIO_URL=http://YOUR_VPS_IP:3000
# WebSocket endpoint used by backend services during agent spin-up progress events.
# Keep this aligned with PLATFORM_WEB_URL for the self-contained PoC.
SOCKET_HOST=http://YOUR_VPS_IP:5000
# Browser origins allowed to call the API gateway from Studio.
# Required for the post-login redirect and for org/country/state/city data to load.
# If you later move Studio behind HTTPS or a real domain, update this list to match that origin.
ENABLE_CORS_IP_LIST=http://YOUR_VPS_IP:3000,http://localhost:3000,http://127.0.0.1:3000
APP_PROTOCOL=http
PLATFORM_NAME=CREDEBL
PUBLIC_PLATFORM_SUPPORT_EMAIL=support@cdpi-poc.local
POWERED_BY=CDPI
POWERED_BY_URL=https://cdpi-poc.local
ORGANIZATION=credebl
CONTEXT=platform
APP=api
CONSOLE_LOG_FLAG=true
ELK_LOG=false
LOG_LEVEL=info
NEXT_PUBLIC_ACTIVE_THEME=credebl

# Platform admin bootstrap values used by the seed container
PLATFORM_ADMIN_EMAIL=admin@cdpi-poc.local
# Keep this default value unless you also re-encrypt
# platformAdminData.password in config/credebl-master-table.json
CRYPTO_PRIVATE_KEY=cdpi-poc-crypto-key-change-me

# Shared-agent / wallet provisioning (required for Studio "Create Shared Wallet")
# If these are blank or inconsistent on first boot, `agent-service` cannot initialize
# the platform-admin shared agent and Studio will show "Shared wallet provisioning is not ready yet".
# IMPORTANT: `WALLET_STORAGE_HOST` must be reachable from the spawned child agent
# container. In this PoC, use the VPS public IP or DNS name instead of `postgres`.
PLATFORM_WALLET_NAME=platformadminwallet
PLATFORM_WALLET_PASSWORD=       # REQUIRED — alphanumeric only; base wallet for the platform-admin shared agent
AGENT_API_KEY=                  # REQUIRED — plain alphanumeric ≥16 chars; MUST NOT start with 'SG.' (that triggers SendGrid validation and breaks agent provisioning)
AGENT_PROTOCOL=http
WALLET_STORAGE_HOST=YOUR_VPS_IP
WALLET_STORAGE_PORT=5432
WALLET_STORAGE_USER=credebl
WALLET_STORAGE_PASSWORD=        # REQUIRED — MUST exactly match POSTGRES_PASSWORD in this PoC

# These paths are relative to /app inside the seed container.
GEO_LOCATION_MASTER_DATA_IMPORT_SCRIPT=libs/prisma-service/prisma/scripts/geo_location_data_import.sh
UPDATE_CLIENT_CREDENTIAL_SCRIPT=libs/prisma-service/prisma/scripts/update_client_credential_data.sh

# ---------------------------------------------------------------------------
# Agent configuration
# ---------------------------------------------------------------------------
# Indy ledger — for PoC use BCovrin Test (public test network)
LEDGER_URL=http://test.bcovrin.vonx.io
GENESIS_URL=http://test.bcovrin.vonx.io/genesis

# Agent port range — each provisioned org agent gets a port in this range
AGENT_PORT_START=8000
AGENT_PORT_END=8099

# AFJ inbound port range — each agent's inbound/public port (must not conflict with MinIO 9000-9001)
# Defaults to 9100+ to avoid MinIO's console and data ports
INBOUND_PORT_START=9100

# Internal AFJ provisioning paths inside the `agent-provisioning` container.
# Keep these defaults for the self-contained PoC unless you rebuild the upstream image differently.
AFJ_VERSION=ghcr.io/credebl/credo-controller:latest
AFJ_AGENT_SPIN_UP=/agent-provisioning/AFJ/scripts/docker_start_agent.sh
AFJ_AGENT_ENDPOINT_PATH=/agent-provisioning/AFJ/endpoints/

# Tails server (for revocation) — public server for PoC
TAILS_FILE_SERVER=https://tails.vonx.io

# ---------------------------------------------------------------------------
# Schema file server
# ---------------------------------------------------------------------------
SCHEMA_FILE_SERVER_PORT=4000
SCHEMA_FILE_SERVER_URL=http://schema-file-server:4000/
SCHEMA_FILE_SERVER_TOKEN=         # REQUIRED for W3C / did:web / did:key schemas; must be a JWT signed with JWT_TOKEN_SECRET
# REQUIRED: must be a valid standard base64 string (no special chars except + / =)
# Generate with: openssl rand -base64 32
JWT_TOKEN_SECRET=                # REQUIRED
ISSUER=Credebl

# ---------------------------------------------------------------------------
# Credential format
# ---------------------------------------------------------------------------
# Options: SD_JWT_VC | AnonCreds | JSON_LD
# For this PoC we use SD_JWT_VC (SD-JWT VC)
CREDENTIAL_FORMAT=SD_JWT_VC

# ---------------------------------------------------------------------------
# OIDC swap variables (Day 5 — real country integration)
# ---------------------------------------------------------------------------
# On Day 5 of the mission, replace KEYCLOAK_PUBLIC_URL with the country's
# real OIDC issuer URL. The values below are pre-filled placeholders.
# Procedure: docs/oidc-swap-procedure.md
#
# OIDC_ISSUER_URL=https://oidc.country.gov/realms/production
# OIDC_CLIENT_ID=credebl-poc
# OIDC_CLIENT_SECRET=<provided by country>
