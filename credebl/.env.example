# =============================================================================
# CDPI PoC — CREDEBL Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in ALL values marked as REQUIRED
# Values marked as OPTIONAL have sensible defaults for PoC use
# NEVER commit .env to git — it is in .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=credebl
POSTGRES_PASSWORD=             # REQUIRED — choose a strong password
POSTGRES_DB=credebl
# If the password contains special URL characters like @, :, or /, URL-encode them here.
DATABASE_URL=postgresql://credebl:${POSTGRES_PASSWORD}@postgres:5432/credebl
POOL_DATABASE_URL=postgresql://credebl:${POSTGRES_PASSWORD}@postgres:5432/credebl

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                # REQUIRED — choose a strong password

# ---------------------------------------------------------------------------
# NATS
# ---------------------------------------------------------------------------
NATS_URL=nats://nats:4222

# ---------------------------------------------------------------------------
# Keycloak (OIDC provider)
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=       # REQUIRED — choose a strong password
KEYCLOAK_DOMAIN=http://keycloak:8080
KEYCLOAK_REALM=credebl-realm
KEYCLOAK_CLIENT_ID=credebl-client
KEYCLOAK_CLIENT_SECRET=        # REQUIRED — generate: openssl rand -hex 32

# Public URL — used by external clients (wallet apps) to reach Keycloak
# In PoC: http://YOUR_VPS_IP:8080
# On day 5 (real OIDC swap): replace with country's real OIDC issuer URL
KEYCLOAK_PUBLIC_URL=http://YOUR_VPS_IP:8080

# ---------------------------------------------------------------------------
# MinIO (replaces AWS S3 — fully containerized)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=           # REQUIRED — choose a strong password

# These values are what CREDEBL services use (S3-compatible API)
AWS_ACCESS_KEY_ID=             # REQUIRED — create in MinIO console after first boot
AWS_SECRET_ACCESS_KEY=         # REQUIRED — create in MinIO console after first boot
AWS_ENDPOINT=http://minio:9000
AWS_REGION=us-east-1           # MinIO ignores this but CREDEBL requires a value
S3_BUCKET_NAME=credebl-bucket

# ---------------------------------------------------------------------------
# Mailpit (replaces SendGrid — fully containerized)
# ---------------------------------------------------------------------------
# Mailpit runs an SMTP server on port 1025
# All sent emails are captured and viewable at http://YOUR_VPS_IP:8025
# No API key needed — just point CREDEBL's email config here
SENDGRID_API_KEY=mailpit-mock  # Placeholder — Mailpit doesn't need a real key
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=noreply@cdpi-poc.local

# ---------------------------------------------------------------------------
# CREDEBL Platform
# ---------------------------------------------------------------------------
API_GATEWAY_PORT=5000
PLATFORM_SEED=                 # REQUIRED — generate: openssl rand -hex 16
JWT_SECRET=                    # REQUIRED — generate: openssl rand -hex 32
JWT_EXPIRY=1d

# Public URL of the API gateway (used in email links and wallet callbacks)
# In PoC: http://YOUR_VPS_IP:5000
API_ENDPOINT=http://YOUR_VPS_IP:5000

# CREDEBL platform URL (for email links)
# In PoC: http://YOUR_VPS_IP:5000
PLATFORM_WEB_URL=http://YOUR_VPS_IP:5000

# ---------------------------------------------------------------------------
# Agent configuration
# ---------------------------------------------------------------------------
# Indy ledger — for PoC use BCovrin Test (public test network)
LEDGER_URL=http://test.bcovrin.vonx.io
GENESIS_URL=http://test.bcovrin.vonx.io/genesis

# Agent port range — each provisioned org agent gets a port in this range
AGENT_PORT_START=8000
AGENT_PORT_END=8099

# Tails server (for revocation) — public server for PoC
TAILS_FILE_SERVER=https://tails.vonx.io

# ---------------------------------------------------------------------------
# Schema file server
# ---------------------------------------------------------------------------
SCHEMA_FILE_SERVER_PORT=4000
SCHEMA_FILE_SERVER_URL=http://schema-file-server:4000

# ---------------------------------------------------------------------------
# Credential format
# ---------------------------------------------------------------------------
# Options: SD_JWT_VC | AnonCreds | JSON_LD
# For this PoC we use SD_JWT_VC (SD-JWT VC)
CREDENTIAL_FORMAT=SD_JWT_VC

# ---------------------------------------------------------------------------
# OIDC swap variables (Day 5 — real country integration)
# ---------------------------------------------------------------------------
# On Day 5 of the mission, replace KEYCLOAK_PUBLIC_URL with the country's
# real OIDC issuer URL. The values below are pre-filled placeholders.
# Procedure: docs/oidc-swap-procedure.md
#
# OIDC_ISSUER_URL=https://oidc.country.gov/realms/production
# OIDC_CLIENT_ID=credebl-poc
# OIDC_CLIENT_SECRET=<provided by country>
