# Agent environment template for spawned Credo agents.
# `scripts/init-credebl.sh` copies these settings into
# `credebl/.agent-runtime/agent.env` and fills in the real host values.
# For manual deployments, copy this file to `.agent-runtime/agent.env` and
# replace `YOUR_PUBLIC_HOST` before running `docker compose up`.

LEDGER_URL=http://test.bcovrin.vonx.io
GENESIS_URL=http://test.bcovrin.vonx.io/genesis
TAILS_FILE_SERVER=https://tails.vonx.io
AGENT_HTTP_URL=http://YOUR_PUBLIC_HOST
AGENT_WS_URL=ws://YOUR_PUBLIC_HOST
CONNECT_TIMEOUT=10
MAX_CONNECTIONS=1000
IDLE_TIMEOUT=30000
SESSION_ACQUIRE_TIMEOUT=2147483647
SESSION_LIMIT=2147483647
INMEMORY_LRU_CACHE_LIMIT=2147483647
TRUST_SERVICE_AUTH_TYPE=NoAuth
TRUST_LIST_URL=https://example.com/trust-list.json
# Wallet storage settings are injected dynamically by `agent-service` during
# provisioning. Do not hard-code `WALLET_STORAGE_*` here because Docker does
# not expand `${POSTGRES_PASSWORD}` inside mounted env files.
