# Environment files — NEVER commit
.env
.env.local
*.env.backup-*

# INJI generated keystore — contains private keys
inji/certs/*.p12
inji/certs/*.key
inji/certs/*.crt
# Keep the placeholder
!inji/certs/.gitkeep

