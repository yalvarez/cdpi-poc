# =============================================================================
# CDPI PoC — INJI Stack Environment Variables
# -----------------------------------------------------------------------------
# These are the variables that docker-compose.yml actually injects into the
# INJI services at runtime. All values are auto-generated by init-inji.sh.
#
# For a full deploy, run:
#   bash scripts/init-inji.sh
#
# Manual setup (if needed):
#   cp .env.example .env
#   Edit .env — fill every REQUIRED value
#   bash scripts/generate-inji-certs.sh   (to create certs/oidckeystore.p12)
#   docker compose up -d
# =============================================================================

# ── Network ──────────────────────────────────────────────────────────────────
# Public-facing base URL of this VPS. No trailing slash.
# Used by Certify for .well-known issuer metadata and OID4VCI redirect URIs.
# Used by Mimoto for wallet callbacks and issuer config.
PUBLIC_URL=http://YOUR_VPS_IP          # REQUIRED

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Single shared database instance. Each service uses its own schema:
#   mockidentitysystem / esignet / certify / mimoto
POSTGRES_USER=inji
POSTGRES_PASSWORD=                      # REQUIRED — generate: openssl rand -hex 16
POSTGRES_DB=mosip_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                         # REQUIRED — generate: openssl rand -hex 16

# ── Inji Certify ──────────────────────────────────────────────────────────────
# CERTIFY_PROFILE controls which data source plugin Certify activates:
#   default        → mock CSV file (inji/config/certify/data/*.csv) — no real DB needed
#   postgres-local → PostgreSQL DataProvider plugin — connects to real data on Day 5
CERTIFY_PROFILE=default

# PKCS12 keystore password — must match the password used when generating
# certs/oidckeystore.p12 via scripts/generate-inji-certs.sh (or init-inji.sh).
CERTIFY_KEYSTORE_PASSWORD=              # REQUIRED — generate: openssl rand -hex 16

# ── Day 5 — OIDC swap ─────────────────────────────────────────────────────────
# On Day 5 replace eSignet with the country's real Authorization Server.
# Steps: update these values → restart inji-certify certify-nginx mimoto
# See inji/docs/oidc-swap-procedure.md for the full procedure.
#
# COUNTRY_OIDC_ISSUER_URL=https://oidc.country.gov/realms/production
# COUNTRY_OIDC_CLIENT_ID=inji-certify-poc
# COUNTRY_OIDC_CLIENT_SECRET=<provided-by-country>
