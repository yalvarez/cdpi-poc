# =============================================================================
# CDPI PoC — INJI Stack Environment Variables
# -----------------------------------------------------------------------------
# Copy to .env and fill ALL values marked as REQUIRED
# NEVER commit .env to git
# =============================================================================

# ---------------------------------------------------------------------------
# Network — VPS public IP or domain
# ---------------------------------------------------------------------------
# Used by Certify for .well-known issuer metadata, OID4VCI redirect URIs,
# and by Mimoto for wallet callbacks
PUBLIC_URL=http://YOUR_VPS_IP      # REQUIRED — replace with your VPS IP or domain

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=inji
POSTGRES_PASSWORD=                  # REQUIRED — strong password
POSTGRES_DB=inji_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=                     # REQUIRED — strong password

# ---------------------------------------------------------------------------
# Inji Certify
# ---------------------------------------------------------------------------
# Profile controls which credential plugin is active
# Options:
#   default        → Mock CSV plugin (for PoC testing without real DB)
#   postgres-local → PostgreSQL DataProvider plugin (connects to real DB)
CERTIFY_PROFILE=default

# Certify signing key password (for SoftHSM keystore)
CERTIFY_KEYSTORE_PASSWORD=          # REQUIRED — generate: openssl rand -hex 16

# Certify DB credentials (can reuse postgres creds)
CERTIFY_DB_USER=certify_user
CERTIFY_DB_PASS=                    # REQUIRED — same or different from POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# eSignet (Authorization Server)
# ---------------------------------------------------------------------------
ESIGNET_DB_USER=esignet_user
ESIGNET_DB_PASS=                    # REQUIRED — strong password

# eSignet OIDC client for Certify
ESIGNET_CLIENT_ID=inji-certify-client
ESIGNET_CLIENT_SECRET=              # REQUIRED — generate: openssl rand -hex 32

# ---------------------------------------------------------------------------
# Mimoto (BFF)
# ---------------------------------------------------------------------------
MIMOTO_DB_USER=mimoto_user
MIMOTO_DB_PASS=                     # REQUIRED — strong password

# ---------------------------------------------------------------------------
# Day 5 — OIDC swap variables
# ---------------------------------------------------------------------------
# On Day 5 replace eSignet with the country's real Authorization Server.
# Change these values and restart esignet-dependent services.
# See docs/oidc-swap-procedure.md for the full procedure.
#
# COUNTRY_OIDC_ISSUER_URL=https://oidc.country.gov/realms/production
# COUNTRY_OIDC_CLIENT_ID=inji-certify-poc
# COUNTRY_OIDC_CLIENT_SECRET=<provided-by-country>
